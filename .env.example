# ── Supabase（第 2 步：supabase.com 新建项目后从 Project Settings → API 复制）──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # 机密，仅服务端使用，切勿泄露

# ── 虎皮椒支付（第 3 步：虎皮椒/迅虎商户后台获取）──
XUNHU_APPID=
XUNHU_APPSECRET=                    # 机密
# 可选：自定义下单接口地址（不填用代码默认值）
# XUNHU_API_URL=

# ── 后台管理员（邮箱白名单）──
# 列出可进 /admin 的邮箱（逗号分隔可多个）。这些邮箱用「邮箱验证码登录」
# 登录后即拥有后台权限，无需密码。OTP/SMTP 在 Supabase 后台配置。
ADMIN_EMAILS=you@example.com

# ── 站点公网域名（部署后填线上域名；本地可填 http://localhost:3000）──
# 自动发卡依赖虎皮椒异步回调，localhost 无法被回调——发卡只在线上生效
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Cloudflare Turnstile 人机验证（可选，登录页「获取验证码」前拦截机器人）──
# dash.cloudflare.com → Turnstile → Add widget，Hostname 填 cngptplus.shop（再加 localhost）
# 两个 key 都填上才启用；留空则跳过人机验证（不影响登录）
NEXT_PUBLIC_TURNSTILE_SITE_KEY=     # 公开，前端 widget 用
TURNSTILE_SECRET_KEY=               # 机密，仅服务端验签用
